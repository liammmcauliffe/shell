.pragma library

const DAY_OF_THE_WEEK = {
    SUNDAY: 0,
    MONDAY: 1,
    TUESDAY: 2,
    WEDNESDAY: 3,
    THURSDAY: 4,
    FRIDAY: 5,
    SATURDAY: 6,
}

// These are the days of the week that will be shown in the calendar header.
function getDaysOfTheWeek(locale) {
    let days = [];
    // We get the name of the days of the week starting from Sunday.
    for (let i = 1; i <= 7; i++) {
        let date = new Date(2023, 0, i);
        // We ensure that the first day of the week is Sunday.
        if (date.getDay() === DAY_OF_THE_WEEK.SUNDAY) {
            for (let j = 0; j < 7; j++) {
                let day = new Date(2023, 0, i + j);
                days.push(day.toLocaleDateString(locale, { weekday: 'short' }));
            }
            break;
        }
    }
    return days;
}

// Get the number of days in a month.
function getDaysInMonth(year, month) {
    return new Date(year, month + 1, 0).getDate();
}

// This is the main function that returns the calendar layout.
function getCalendarLayout(year, month) {
    let layout = [];
    let daysInMonth = getDaysInMonth(year, month);
    let firstDay = new Date(year, month, 1).getDay();
    let day = 1;

    for (let i = 0; i < 6; i++) {
        let week = [];
        for (let j = 0; j < 7; j++) {
            if (i === 0 && j < firstDay) {
                week.push(0);
            } else if (day > daysInMonth) {
                week.push(0);
            } else {
                week.push(day);
                day++;
            }
        }
        layout.push(week);
    }

    // This is a check to remove the last week if it is empty.
    let lastWeek = layout[5];
    let sum = 0;
    for (let i = 0; i < lastWeek.length; i++) {
        sum += lastWeek[i];
    }
    if (sum === 0) {
        layout.pop();
    }

    return layout;
}
